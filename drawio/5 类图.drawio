      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="数据库表关系说明" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="400" height="30" as="geometry" />
        </mxCell>
        <!-- sys_user -->
        <mxCell id="t_user" value="sys_user&#xa;(用户表)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="140" height="50" as="geometry" />
        </mxCell>
        <!-- parking_area -->
        <mxCell id="t_area" value="parking_area&#xa;(停车区域表)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="100" width="150" height="50" as="geometry" />
        </mxCell>
        <!-- parking_space -->
        <mxCell id="t_space" value="parking_space&#xa;(停车位表)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="250" width="150" height="50" as="geometry" />
        </mxCell>
        <!-- parking_record -->
        <mxCell id="t_record" value="parking_record&#xa;(停车记录表)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="250" width="150" height="50" as="geometry" />
        </mxCell>
        <!-- fee_rule -->
        <mxCell id="t_fee" value="fee_rule&#xa;(收费规则表)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="100" width="140" height="50" as="geometry" />
        </mxCell>
        <!-- operation_log -->
        <mxCell id="t_log" value="operation_log&#xa;(操作日志表)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="50" y="250" width="140" height="50" as="geometry" />
        </mxCell>
        <!-- 关系连线 -->
        <mxCell id="rel_area_space" edge="1" parent="1" source="t_area" style="endArrow=open;endFill=0;fontSize=11;strokeColor=#000000;" target="t_space" value="1:N (一个区域多个车位)">
          <mxGeometry relative="1" x="0" y="-10" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="rel_space_record" edge="1" parent="1" source="t_space" style="endArrow=open;endFill=0;fontSize=11;strokeColor=#000000;" target="t_record" value="1:N (一个车位多条记录)">
          <mxGeometry relative="1" x="0" y="-10" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="rel_fee_record" edge="1" parent="1" source="t_fee" style="endArrow=open;endFill=0;fontSize=11;dashed=1;strokeColor=#b85450;" target="t_record" value="收费规则参考">
          <mxGeometry relative="1" x="0" y="10" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="rel_user_log" edge="1" parent="1" source="t_user" style="endArrow=open;endFill=0;fontSize=11;strokeColor=#000000;" target="t_log" value="1:N (用户产生日志)">
          <mxGeometry relative="1" x="0" y="-10" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
